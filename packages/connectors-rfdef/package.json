{
  "name": "@argus/connectors-rfdef",
  "version": "0.1.0",
  "description": "Defensive RF/wireless sensor connectors (Kismet, rtl-sdr, bettercap) -> ARGUS ontology, with an authorized-MAC-prefix gate.",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@argus/ontology": "workspace:*",
    "@argus/connectors": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "vitest": "^1.6.0"
  }
}
