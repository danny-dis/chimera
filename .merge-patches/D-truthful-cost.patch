+      // interface (the only thing it knows about) does not declare
+      // these methods. The concrete providers (Anthropic, OpenAI, etc.)
+      // do expose them at runtime — the function's runtime check
+      // `typeof provider.getCost === 'function'` falls back to the
+      // static rates when they are missing (e.g. MockProvider or
+      // test stubs).
+      getCost?: (tokens: { input: number; output: number }) => number;
+      getPricing?: () => {
+        inputPerMillion: number;
+        outputPerMillion: number;
+        cacheReadPerMillion?: number;
+        cacheWritePerMillion?: number;
+      };
+    },
+  ): number {
+    // Provider-truthful path: use the provider's own pricing table so
+    // prompt-caching and per-model rates are honored. We compute from
+    // `getPricing` rather than `getCost` because `getCost` does not
+    // surface the cache rates. The structural type accepts both
+    // `ModelProvider` (e.g. AnthropicProvider, OpenAICompatibleProvider)
+    // and the `MockProvider` / orchestrator `LLMProvider` used in tests
+    // — when the methods are absent, we fall through to the static
+    // fallback rates.
+    if (provider && typeof provider.getCost === 'function' && typeof provider.getPricing === 'function') {
