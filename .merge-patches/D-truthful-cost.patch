@@ -387,4 +387,88 @@ describe('SessionOrchestrator', () => {
       expect(result.status).toBe('done');
     });
   });
+
+  describe('estimateCost', () => {
+    it('falls back to static rates when no provider hint is given', () => {
+      const cost = orchestrator['estimateCost']({ inputTokens: 1_000_000, outputTokens: 1_000_000 });
+      // Static rates: $0.50/M input, $1.50/M output → $2.00
+      expect(cost).toBeCloseTo(2.0);
+    });
+
+    it('uses the provider pricing (mocked) when getPricing is available', () => {
+      const provider = {
+        getCost: vi.fn(),
+        getPricing: () => ({
+          inputPerMillion: 10,
+          outputPerMillion: 20,
+          cacheReadPerMillion: 1,
+          cacheWritePerMillion: 12.5,
+        }),
+      };
+
+      const cost = orchestrator['estimateCost'](
+        { inputTokens: 1_000_000, outputTokens: 1_000_000 },
+        provider,
+      );
+      // (uncached 1M * 10 + cache 0 * 1 + cache-write 0 * 12.5) / 1e6
+      // + (1M * 20) / 1e6 = 10 + 20 = 30
+      expect(cost).toBeCloseTo(30);
+      // getCost is intentionally NOT called — the orchestrator computes
+      // cost directly from getPricing() so it can apply the cache
+      // rates that getCost() doesn't expose.
+      expect(provider.getCost).not.toHaveBeenCalled();
+    });
+
+    it('returns a lower cost when cacheReadTokens is set (cache reads are cheap)', () => {
+      const provider = {
+        getCost: vi.fn((tokens: { input: number; output: number }) =>
+          (tokens.input * 10 + tokens.output * 20) / 1_000_000,
+        ),
+        getPricing: () => ({
+          inputPerMillion: 10,
+          outputPerMillion: 20,
+          cacheReadPerMillion: 1, // 10x cheaper than uncached input
+          cacheWritePerMillion: 12.5,
+        }),
+      };
+
+      const withoutCache = orchestrator['estimateCost'](
+        { inputTokens: 1_000_000, outputTokens: 1_000_000 },
+        provider,
+      );
+      const withCache = orchestrator['estimateCost'](
+        { inputTokens: 1_000_000, outputTokens: 1_000_000, cacheReadTokens: 800_000 },
+        provider,
+      );
+
+      // withoutCache = 30 (1M * 10/M + 1M * 20/M)
+      // withCache    = (200k * 10 + 800k * 1) / 1e6 + 1M * 20 / 1e6
+      //             = 2 + 0.8 + 20 = 22.8  → strictly lower
+      expect(withoutCache).toBeCloseTo(30);
+      expect(withCache).toBeCloseTo(22.8);
+      expect(withCache).toBeLessThan(withoutCache);
+    });
+
+    it('charges cacheWriteTokens at the cacheWritePerMillion rate on top of uncached input', () => {
+      const provider = {
+        getCost: vi.fn(),
+        getPricing: () => ({
+          inputPerMillion: 10,
+          outputPerMillion: 20,
+          cacheReadPerMillion: 1,
+          cacheWritePerMillion: 12.5,
+        }),
+      };
+
+      // 1M total input, 0 cache-read (so the full 1M is treated as
+      // uncached and billed at the input rate), plus 500k cache-write
+      // billed at cacheWritePerMillion.
+      const cost = orchestrator['estimateCost'](
+        { inputTokens: 1_000_000, outputTokens: 0, cacheWriteTokens: 500_000 },
+        provider,
+      );
+      // (1M * 10 + 0 + 500k * 12.5) / 1e6 + 0 = 10 + 6.25 = 16.25
+      expect(cost).toBeCloseTo(16.25);
+    });
+  });
 });
