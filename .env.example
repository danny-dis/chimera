# Chimera environment configuration
# Copy this file to `.env` (which is gitignored) and fill in your values.
#
# Provider roles are configured in .chimera/config.yaml.
# Run `chimera setup` to configure roles interactively, or create the file manually.
# API keys stay here (.env), role assignments go in config.yaml.

# ---------------------------------------------------------------------------
# Cheap / bulk provider — openai-compatible proxy.
# Works with: Mistral, NVIDIA NIM, OpenRouter, Together, TokenRouter, etc.
# IMPORTANT: do NOT include the /v1 suffix — the provider appends /v1/chat/completions.
#
# Examples:
#   CHIMERA_CHEAP_BASE_URL=https://api.mistral.ai
#   CHIMERA_CHEAP_API_KEY=your-mistral-key
#   CHIMERA_CHEAP_MODEL=mistral-small-latest
#
#   CHIMERA_CHEAP_BASE_URL=https://integrate.api.nvidia.com
#   CHIMERA_CHEAP_API_KEY=your-nvidia-nim-key
#   CHIMERA_CHEAP_MODEL=meta/llama-3.1-8b-instruct
#
#   CHIMERA_CHEAP_BASE_URL=https://openrouter.ai/api
#   CHIMERA_CHEAP_API_KEY=your-openrouter-key
#   CHIMERA_CHEAP_MODEL=meta-llama/llama-3.1-8b-instruct
# ---------------------------------------------------------------------------
CHIMERA_CHEAP_BASE_URL=
CHIMERA_CHEAP_API_KEY=
CHIMERA_CHEAP_MODEL=

# ---------------------------------------------------------------------------
# Frontier providers (optional, leave blank to skip).
# If CHIMERA_CHEAP is configured, it takes the "writer" role.
# Frontier providers fill "reviewer" and "challenger" roles automatically.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.5-flash

# ---------------------------------------------------------------------------
# Per-role model overrides (optional).
# When set, these create dedicated provider entries for each role.
# Uses whichever API key is available (Anthropic > OpenAI > Google).
# ---------------------------------------------------------------------------
# CHIMERA_WRITER_MODEL=
# CHIMERA_REVIEWER_MODEL=
# CHIMERA_CHALLENGER_MODEL=

# ---------------------------------------------------------------------------
# Local Ollama (no key required, just set the model name).
# ---------------------------------------------------------------------------
OLLAMA_MODEL=

# ---------------------------------------------------------------------------
# Web Search (optional - DuckDuckGo works out of the box, no key needed)
# ---------------------------------------------------------------------------
# SearXNG self-hosted instance URL (for privacy-focused search)
SEARXNG_BASE_URL=

# Brave Search API key (free tier: 2,000 queries/month)
# Get your key at: https://brave.com/search/api/
BRAVE_API_KEY=

# ---------------------------------------------------------------------------
# Example .chimera/config.yaml:
#
# providers:
#   - name: writer
#     provider: openai-compatible
#     model: mistral-small-latest
#     api_key: ${CHIMERA_CHEAP_API_KEY}
#     base_url: https://api.mistral.ai
#     role: writer
#   - name: reviewer
#     provider: google
#     model: gemini-2.5-flash
#     api_key: ${GOOGLE_API_KEY}
#     role: reviewer
#   - name: challenger
#     provider: anthropic
#     model: claude-sonnet-4-20250514
#     api_key: ${ANTHROPIC_API_KEY}
#     role: challenger
#
# Run `chimera setup` to configure interactively.
# Use `/preset <auto|solo|duo|trio|hive|fusion>` in REPL to switch agent topology.
# Use `/mode <ask|plan|code|debug|review|oal|auto>` to switch task intent.
# ---------------------------------------------------------------------------
