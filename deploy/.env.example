# =============================================================================
# Chimera deploy — environment example
# Copy to .env and fill in. Read by docker-compose.yml and (optionally) Caddy.
# =============================================================================

# --- Caddy / TLS (only needed with `docker compose --profile cloud`) ---
# Point this domain's DNS A record at your server before starting Caddy.
DOMAIN=chimera.example.com

# --- Daemon bridge port (only needed when fronting the stdio daemon with Caddy) ---
# The chimera-daemon is stdio-only. If you run a stdio→TCP bridge inside the
# container, set the port it listens on here (Caddyfile + compose use this).
CHIMERA_DAEMON_PORT=4173

# --- Optional: basic auth for the Caddy proxy ---
# Generate: docker run caddy caddy hash-password --plaintext 'YOUR_PASSWORD'
# Escape $ as $$ in this file.
# CADDY_BASIC_AUTH=basicauth @protected { admin $$2a$$14$$<hash> }

# --- Provider credentials (consumed by .chimera/config.yaml) ---
# Chimera's providers are configured in ~/.chimera/config.yaml, not here.
# Set any API keys your config references as env vars below, e.g.:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
